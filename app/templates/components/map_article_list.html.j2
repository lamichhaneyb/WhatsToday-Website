{% if articles %}
  {% for article in articles %}
  <article class="mapArticleCard{% if not article.image_url %} no-image{% endif %}" onclick="window.open('{{ article.url }}', '_blank')">
    {% if current_user %}
      <form class="saveForm saveFormFloating" action="{{ url_for('saved.add_saved_article') }}" method="post" onclick="event.stopPropagation()">
        <input type="hidden" name="title" value="{{ article.title }}">
        <input type="hidden" name="description" value="{{ article.description }}">
        <input type="hidden" name="url" value="{{ article.url }}">
        <input type="hidden" name="image_url" value="{{ article.image_url or '' }}">
        <input type="hidden" name="source" value="{{ article.source }}">
        <input type="hidden" name="article_type" value="{{ article.article_type }}">
        <button class="bookmarkButton" type="submit" title="Save article" aria-label="Save article"><span aria-hidden="true"></span></button>
      </form>
    {% else %}
      <button class="bookmarkButton saveFormFloating loginRequiredSave" type="button" title="Save article" aria-label="Save article" onclick="event.stopPropagation()"><span aria-hidden="true"></span></button>
    {% endif %}

    {% if article.image_url %}
      <div class="mapArticleImage">
        <img src="{{ article.image_url }}" alt="{{ article.title }}" loading="lazy">
      </div>
    {% endif %}
    <div class="mapArticleBody">
      <p class="articleSource">{{ article.source }}</p>
      <h2 class="mapArticleTitle">{{ article.title }}</h2>
      <p class="mapArticleDesc">{{ article.description }}</p>
    </div>
  </article>
  {% endfor %}
{% else %}
  <p class="emptyState">No articles found for {{ country_name }}.</p>
{% endif %}
